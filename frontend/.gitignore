# ══════════════════════════════════════════════════════════════════════════════
# Angular / Node.js — Frontend .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# Зависимости
# ──────────────────────────────────────────────────────────────────────────────

node_modules/
.pnp/
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ──────────────────────────────────────────────────────────────────────────────
# Сборка
# ──────────────────────────────────────────────────────────────────────────────

dist/
dist-ssr/
build/
out/
tmp/
out-tsc/
bazel-out/

# ──────────────────────────────────────────────────────────────────────────────
# Angular
# ──────────────────────────────────────────────────────────────────────────────

.angular/
.nx/
angular.local.json

# ──────────────────────────────────────────────────────────────────────────────
# Тестирование
# ──────────────────────────────────────────────────────────────────────────────

coverage/
.nyc_output/
junit.xml
test-results/
playwright-report/
playwright/.cache/
e2e-results/

# Karma
karma-results/

# Cypress
cypress/videos/
cypress/screenshots/
cypress/downloads/

# ──────────────────────────────────────────────────────────────────────────────
# Логи NPM/Yarn/PNPM
# ──────────────────────────────────────────────────────────────────────────────

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# ──────────────────────────────────────────────────────────────────────────────
# Переменные окружения
# ──────────────────────────────────────────────────────────────────────────────

.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ──────────────────────────────────────────────────────────────────────────────
# Редакторы и IDE
# ──────────────────────────────────────────────────────────────────────────────

# VS Code (специфичные для frontend)
.vscode/chrome/
.vscode/.browse.c_cpp.db*
.vscode/*.log

# ──────────────────────────────────────────────────────────────────────────────
# TypeScript
# ──────────────────────────────────────────────────────────────────────────────

*.tsbuildinfo
.tscache/

# ──────────────────────────────────────────────────────────────────────────────
# ESLint / Prettier
# ──────────────────────────────────────────────────────────────────────────────

.eslintcache
.stylelintcache

# ──────────────────────────────────────────────────────────────────────────────
# Storybook
# ──────────────────────────────────────────────────────────────────────────────

storybook-static/

# ──────────────────────────────────────────────────────────────────────────────
# SSR (Server-Side Rendering)
# ──────────────────────────────────────────────────────────────────────────────

.output/
.vercel/
.netlify/

# ──────────────────────────────────────────────────────────────────────────────
# Разное
# ──────────────────────────────────────────────────────────────────────────────

*.local
.cache/
.parcel-cache/
.turbo/
.vite/
