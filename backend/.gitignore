# .NET tools
# ──────────────────────────────────────────────────────────────────────────────

.config/dotnet-tools.json.bak

# ──────────────────────────────────────────────────────────────────────────────
# BenchmarkDotNet
# ──────────────────────────────────────────────────────────────────────────────

BenchmarkDotNet.Artifacts/

# ──────────────────────────────────────────────────────────────────────────────
