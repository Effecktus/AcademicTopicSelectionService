# ══════════════════════════════════════════════════════════════════════════════
# .NET / ASP.NET Core — Backend .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# Сборка
# ──────────────────────────────────────────────────────────────────────────────

[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]uild/
[Dd]ebugPublic/
[Rr]elease[Pp]ublic/

# ──────────────────────────────────────────────────────────────────────────────
# MSBuild
# ──────────────────────────────────────────────────────────────────────────────

*.msbuild.log
*.msbuild.err
*.msbuild.wrn

# ──────────────────────────────────────────────────────────────────────────────
# Visual Studio
# ──────────────────────────────────────────────────────────────────────────────

*.csproj.user
*.rsuser
*.pidb
*.svclog
*.scc

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build output directories
[Aa][Pp][Pp]_[Dd]ata/

# ──────────────────────────────────────────────────────────────────────────────
# NuGet
# ──────────────────────────────────────────────────────────────────────────────

*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
.nuget/
nuget.exe
project.lock.json
project.fragment.lock.json
artifacts/

# ──────────────────────────────────────────────────────────────────────────────
# Entity Framework
# ──────────────────────────────────────────────────────────────────────────────

# Локальные миграции не игнорируем (они важны!), но игнорируем сгенерированные snapshot-ы для IDE
# *.Designer.cs (осторожно — могут быть нужны)

# ──────────────────────────────────────────────────────────────────────────────
# ASP.NET Core
# ──────────────────────────────────────────────────────────────────────────────

**/Properties/PublishProfiles/
**/Properties/launchSettings.Local.json
**/wwwroot/dist/
**/wwwroot/lib/

# ──────────────────────────────────────────────────────────────────────────────
# User Secrets (local development)
# ──────────────────────────────────────────────────────────────────────────────

# Обычно хранятся в %APPDATA%\Microsoft\UserSecrets, но на всякий случай
secrets.json
appsettings.Local.json
appsettings.Secrets.json

# ──────────────────────────────────────────────────────────────────────────────
# Тестирование
# ──────────────────────────────────────────────────────────────────────────────

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResults/
*.trx
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage/

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# SpecFlow
*.feature.cs

# ──────────────────────────────────────────────────────────────────────────────
# Code coverage
# ──────────────────────────────────────────────────────────────────────────────

*.opencover.xml
lcov.info
coverage-report/

# ──────────────────────────────────────────────────────────────────────────────
# JetBrains Rider
# ──────────────────────────────────────────────────────────────────────────────

.idea/
*.sln.iml

# ──────────────────────────────────────────────────────────────────────────────
# Swagger
# ──────────────────────────────────────────────────────────────────────────────

# Если swagger.json генерируется автоматически — можно игнорировать
# swagger.json

