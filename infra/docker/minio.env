# Переменные окружения MinIO Server.
# Учётная запись root задаётся через Docker secrets (minio_access_key.txt / minio_secret_key.txt),
# не дублируйте логин и пароль здесь.

# Веб-консоль (порт задаётся в compose: --console-address ":9001").
MINIO_BROWSER=on

# Раскомментируйте, если API доступен с другого публичного URL (reverse-proxy, HTTPS и т.д.).
# MINIO_SERVER_URL=http://localhost:9000

# Необязательно: домен для virtual-host стиля имён бакетов.
# MINIO_DOMAIN=
