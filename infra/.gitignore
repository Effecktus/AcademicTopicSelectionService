# ══════════════════════════════════════════════════════════════════════════════
# Infrastructure — Docker, Terraform, DB, Monitoring .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────────────────────────────────────

# Локальные переопределения compose файлов
docker-compose.override.yml
docker-compose.local.yml

# Логи Docker
*.docker.log

# Временные файлы Docker
.docker/

# ──────────────────────────────────────────────────────────────────────────────
# Секреты (КРИТИЧНО!)
# ──────────────────────────────────────────────────────────────────────────────

# Docker secrets
docker/secrets/*
!docker/secrets/.gitkeep

# Любые файлы с секретами
*.secret
*.secrets
*.key
*.pem
*.p12
*.pfx
*password*
*credentials*

# SSL сертификаты (локальные)
docker/ssl/
*.crt
*.cer
!docker/ssl/.gitkeep

# ──────────────────────────────────────────────────────────────────────────────
# База данных
# ──────────────────────────────────────────────────────────────────────────────

# Бэкапы БД
db/backups/*
!db/backups/.gitkeep

# Данные БД (volumes)
db/data/
db/pgdata/
postgres-data/

# Дампы
*.sql.gz
*.dump
*.dump.gz
*.bak

# ──────────────────────────────────────────────────────────────────────────────
# Terraform
# ──────────────────────────────────────────────────────────────────────────────

# Локальная директория Terraform
terraform/.terraform/
**/.terraform/

# Файлы состояния
terraform/*.tfstate
terraform/*.tfstate.*
*.tfstate
*.tfstate.*

# Файлы переменных (могут содержать секреты)
terraform/*.tfvars
terraform/*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Файлы планов (могут содержать чувствительные данные)
terraform/*.tfplan
*.tfplan

# Переопределения (используются локально)
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Crash logs
crash.log
crash.*.log

# ──────────────────────────────────────────────────────────────────────────────
# Monitoring
# ──────────────────────────────────────────────────────────────────────────────

# Grafana
monitoring/grafana/data/
monitoring/grafana/provisioning/dashboards/*.json.bak
monitoring/grafana/plugins/

# Prometheus
monitoring/prometheus/data/

# AlertManager
monitoring/alertmanager/data/

# Loki
monitoring/loki/data/

# ──────────────────────────────────────────────────────────────────────────────
# Kubernetes (если будет использоваться)
# ──────────────────────────────────────────────────────────────────────────────

# Kubeconfig
kubeconfig
.kube/

# Helm
charts/*.tgz
*.lock

# Sealed secrets
*-sealed.yaml

# ──────────────────────────────────────────────────────────────────────────────
# Ansible (если будет использоваться)
# ──────────────────────────────────────────────────────────────────────────────

*.retry
ansible/inventory/local
ansible/group_vars/all/vault.yml

# ──────────────────────────────────────────────────────────────────────────────
# Временные файлы
# ──────────────────────────────────────────────────────────────────────────────

*.tmp
*.temp
*.log
